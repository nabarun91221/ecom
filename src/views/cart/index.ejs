<!doctype html><html><head><title>Your cart</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"></head><body class="bg-light"><%- include('../layouts/nav.ejs') %><main class="container py-4"><h2>Your cart</h2><% const active=cart.items.filter(i=>!i.savedForLater), saved=cart.items.filter(i=>i.savedForLater); const total=active.reduce((sum,i)=>sum+(i.product?.price||0)*i.quantity,0); %><% if(error?.[0]){%><div class="alert alert-danger"><%=error[0]%></div><%}%><div class="row"><section class="col-lg-8"><% if(!cart.items.length){%><div class="card card-body">Your cart is empty. <a href="/web/products">Browse products</a></div><%}%><% for(const item of active){ %><div class="card card-body mb-2"><div class="d-flex justify-content-between"><div><strong><%=item.product?.name||'Unavailable product'%></strong><div>₹ <%=item.product?.price||0%></div></div><div class="d-flex gap-2"><form method="POST" action="/web/cart/item/<%=item._id%>/quantity"><input type="number" name="quantity" min="1" value="<%=item.quantity%>" style="width:70px"><button class="btn btn-sm btn-outline-primary">Update</button></form><form method="POST" action="/web/cart/item/<%=item._id%>/save"><input type="hidden" name="saved" value="true"><button class="btn btn-sm btn-outline-secondary">Save for later</button></form><form method="POST" action="/web/cart/item/<%=item._id%>/remove"><button class="btn btn-sm btn-outline-danger">Remove</button></form></div></div></div><%}%><% if(saved.length){%><h4 class="mt-4">Saved for later</h4><%for(const item of saved){%><div class="card card-body mb-2 d-flex flex-row justify-content-between"><span><%=item.product?.name||'Unavailable product'%></span><form method="POST" action="/web/cart/item/<%=item._id%>/save"><input type="hidden" name="saved" value="false"><button class="btn btn-sm btn-outline-primary">Move to cart</button></form></div><%}%><%}%></section><aside class="col-lg-4"><div class="card card-body"><h4>Order summary</h4><p>Total: <strong>₹ <%=total%></strong></p><form method="POST" action="/web/cart/checkout"><button class="btn btn-success w-100" <%=active.length?'':'disabled'%>>Checkout</button></form></div></aside></div></main></body></html>
