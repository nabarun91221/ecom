<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"><title>Manage <%= type %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
  <%- include('../layouts/nav.ejs') %>
  <main class="container py-4 py-lg-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
      <div><h2 class="h3 text-capitalize mb-1">Manage <%= type %></h2><p class="text-muted mb-0">Create, update, and control catalog availability.</p></div>
      <span class="badge text-bg-primary rounded-pill"><%= records.length %> total</span>
    </div>
    <% if(success?.[0]) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
    <% if(error?.[0]) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>

    <section class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <h3 class="h6 mb-3">Add <%= type.slice(0, -1) %></h3>
        <form method="POST" class="row g-3 align-items-end">
          <div class="col-md-7"><label class="form-label">Name</label><input required class="form-control" name="name" placeholder="Enter name"></div>
          <div class="col-md-3"><label class="form-label">Status</label><select class="form-select" name="status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
          <div class="col-md-2 d-grid"><button class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add</button></div>
        </form>
      </div>
    </section>

    <section class="card border-0 shadow-sm overflow-hidden">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light"><tr><th class="ps-4">Name</th><th>Status</th><th>State</th><th class="text-end pe-4">Actions</th></tr></thead>
          <tbody>
            <% records.forEach(record => { %>
              <tr class="<%= record.isDeleted ? 'table-secondary' : '' %>">
                <td class="ps-4"><form id="update-<%=record.id%>" method="POST" action="/web/admin/<%=type%>/<%=record.id%>"><input class="form-control" name="name" value="<%=record.name%>"></form></td>
                <td><select form="update-<%=record.id%>" name="status" class="form-select"><option value="active" <%=record.status==='active'?'selected':''%>>Active</option><option value="inactive" <%=record.status==='inactive'?'selected':''%>>Inactive</option></select></td>
                <td><span class="badge <%=record.isDeleted ? 'text-bg-secondary' : record.status === 'active' ? 'text-bg-success' : 'text-bg-warning'%>"><%=record.isDeleted ? 'Soft deleted' : record.status%></span></td>
                <td class="pe-4"><div class="d-flex justify-content-end flex-wrap gap-2"><button form="update-<%=record.id%>" class="btn btn-sm btn-outline-primary">Save</button><form method="POST" action="/web/admin/<%=type%>/<%=record.id%>/delete"><input type="hidden" name="deleted" value="<%=!record.isDeleted%>"><button class="btn btn-sm btn-outline-warning"><%=record.isDeleted?'Restore':'Soft delete'%></button></form><form method="POST" action="/web/admin/<%=type%>/<%=record.id%>/hard-delete" onsubmit="return confirm('Permanently delete this record?')"><button class="btn btn-sm btn-outline-danger">Hard delete</button></form></div></td>
              </tr>
            <% }) %>
            <% if (!records.length) { %><tr><td colspan="4" class="text-center text-muted py-5">No <%= type %> yet. Add your first one above.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
