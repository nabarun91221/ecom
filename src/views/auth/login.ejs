<!doctype html><html><head><title>Login</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"></head><body class="bg-light"><main class="container py-5" style="max-width:480px"><h2>Welcome back</h2><% if (error?.[0]) { %><div class="alert alert-danger"><%= error[0] %></div><% } %><form method="POST" action="/web/auth/login" class="card card-body shadow-sm"><input type="hidden" name="next" value="<%= next %>"><label class="mb-2">Email<input required type="email" name="email" class="form-control"></label><label class="mb-3">Password<input required type="password" name="password" class="form-control"></label><button class="btn btn-primary">Login</button></form><p class="mt-3">New here? <a href="/web/auth/signup">Create an account</a></p></main></body></html>
