<!doctype html><html><head><title>Sign up</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"></head><body class="bg-light"><main class="container py-5" style="max-width:480px"><h2>Create account</h2><% if (error?.[0]) { %><div class="alert alert-danger"><%= error[0] %></div><% } %><form method="POST" action="/web/auth/signup" class="card card-body shadow-sm"><label class="mb-2">Name<input required name="name" class="form-control"></label><label class="mb-2">Email<input required type="email" name="email" class="form-control"></label><label class="mb-3">Password <small>(8+ characters)</small><input required minlength="8" type="password" name="password" class="form-control"></label><button class="btn btn-primary">Create account</button></form><p class="mt-3">Already registered? <a href="/web/auth/login">Login</a></p></main></body></html>
